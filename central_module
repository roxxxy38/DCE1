void printByte(byte character[]) {
  lc.clearDisplay(0);
  for (int i = 0; i < 8; i++) {
    lc.setRow(0, i, character[i]);
  }
}

void stepWithYield(int steps) {
  int dir   = (steps > 0) ? 1 : -1;
  int total = abs(steps);
  for (int i = 0; i < total; i++) {
    myStepper.step(dir);
    if (i % 50 == 0) yield();
  }
}

void processMessage() {
  Serial.println("--- message received ---");
  Serial.print("eyes_solved: ");  Serial.println(oocsi.getBool("eyes_solved", false));
  Serial.print("active: ");       Serial.println(oocsi.getBool("active", false));
  Serial.print("solved: ");       Serial.println(oocsi.getBool("solved", false));
  Serial.print("morse_solved: "); Serial.println(oocsi.getBool("morse_solved", false));
  Serial.print("calc_solved: ");  Serial.println(oocsi.getBool("calc_solved", false));
  Serial.print("flags: eyesDone=");      Serial.print(eyesDone);
  Serial.print(" signalSent=");          Serial.print(signalSent);
  Serial.print(" highlightDone=");       Serial.print(highlightDone);
  Serial.print(" morseDone=");           Serial.print(morseDone);
  Serial.print(" calcDone=");            Serial.println(calcDone);

  bool requestState = oocsi.getBool("requestState", false);
  if (requestState) {
    if (signalSent) {
      oocsi.newMessage("TEAM12_HIGHLIGHTER");
      oocsi.addBool("trigger", true);
      oocsi.sendMessage();
      Serial.println("Re-sent trigger to late-joining highlighter");
    }
    return;
  }

  bool eyes_solved = oocsi.getBool("eyes_solved", false);
  if (eyes_solved && !eyesDone) {
    eyesDone = true;
    Serial.println("Eyes solved!");
    oocsi.newMessage("TEAM12_BOOKSHELF_CLIENT");
    oocsi.addBool("start", true);
    oocsi.sendMessage();
    stepWithYield(stepsPerRevolution / numberOfPuzzles);
    printByte(C);
    delay(2000);
    return;
  }

  bool active = oocsi.getBool("active", false);
  if (active && !signalSent) {
    signalSent = true;
    Serial.println("Sending trigger to highlighter...");
    oocsi.newMessage("TEAM12_HIGHLIGHTER");
    oocsi.addBool("trigger", true);
    oocsi.sendMessage();
    stepWithYield(stepsPerRevolution / numberOfPuzzles);
    printByte(A);
    delay(2000);
    return;
  }

  bool solved = oocsi.getBool("solved", false);
  if (solved && !highlightDone) {
    highlightDone = true;
    Serial.println("Highlighter solved!");
    oocsi.newMessage("TEAM12_ESP3_CLIENT");
    oocsi.addBool("start", true);
    oocsi.sendMessage();
    stepWithYield(stepsPerRevolution / numberOfPuzzles);
    printByte(D);
    delay(2000);
    return;
  }

  bool morse_solved = oocsi.getBool("morse_solved", false);
  if (morse_solved && !morseDone) {
    morseDone = true;
    Serial.println("Morse solved!");
    oocsi.newMessage("TEAM12_CALCULATOR");
    oocsi.addBool("start", true);
    oocsi.sendMessage();
    stepWithYield(stepsPerRevolution / numberOfPuzzles);
    printByte(B_);
    delay(2000);
    return;
  }

  bool calc_solved = oocsi.getBool("calc_solved", false);
  if (calc_solved && !calcDone) {
    calcDone = true;
    Serial.println("Escape room complete!");
    stepWithYield(stepsPerRevolution / numberOfPuzzles);
    printByte(B_);
    delay(2000);
    return;
  }
}

void calibrateClock() {
  if (Serial.available() > 0) {
    String input = Serial.readStringUntil('\n');
    input.trim();

    if (input.startsWith("L:") && input.length() == 3) {
      char letter = input.charAt(2);
      Serial.print("Displaying letter: ");
      Serial.println(letter);
      switch (letter) {
        case 'A': printByte(A); break;
        case 'B': printByte(B_); break;
        case 'C': printByte(C); break;
        case 'D': printByte(D); break;
        case 'E': printByte(E); break;
        case 'F': printByte(F); break;
        case 'G': printByte(G); break;
        case 'H': printByte(H); break;
        case 'I': printByte(I); break;
        case 'J': printByte(J); break;
        case 'K': printByte(K); break;
        case 'L': printByte(L); break;
        case 'M': printByte(M); break;
        case 'N': printByte(N); break;
        case 'O': printByte(O); break;
        case 'P': printByte(P); break;
        case 'Q': printByte(Q); break;
        case 'R': printByte(R); break;
        case 'S': printByte(S); break;
        case 'T': printByte(T); break;
        case 'U': printByte(U); break;
        case 'V': printByte(V); break;
        case 'W': printByte(W); break;
        case 'X': printByte(X); break;
        case 'Y': printByte(Y); break;
        case 'Z': printByte(Z); break;
        case '?': printByte(RND); break;
        default: Serial.println("Unknown letter. Use L:A through L:Z"); break;
      }

    } else if (input == "T:1") {
      if (!eyesDone) {
        eyesDone = true;
        Serial.println("Manual T:1 — triggering bookshelf...");
        oocsi.newMessage("TEAM12_BOOKSHELF_CLIENT");
        oocsi.addBool("start", true);
        oocsi.sendMessage();
        stepWithYield(stepsPerRevolution / numberOfPuzzles);
        printByte(C);
      } else { Serial.println("T:1 already done."); }

    } else if (input == "T:2") {
      if (!signalSent) {
        signalSent = true;
        Serial.println("Manual T:2 — triggering highlighter...");
        oocsi.newMessage("TEAM12_HIGHLIGHTER");
        oocsi.addBool("trigger", true);
        oocsi.sendMessage();
        stepWithYield(stepsPerRevolution / numberOfPuzzles);
        printByte(A);
      } else { Serial.println("T:2 already done."); }

    } else if (input == "T:3") {
      if (!highlightDone) {
        highlightDone = true;
        Serial.println("Manual T:3 — triggering morse...");
        oocsi.newMessage("TEAM12_ESP3_CLIENT");
        oocsi.addBool("start", true);
        oocsi.sendMessage();
        stepWithYield(stepsPerRevolution / numberOfPuzzles);
        printByte(D);
      } else { Serial.println("T:3 already done."); }

    } else if (input == "T:4") {
      if (!morseDone) {
        morseDone = true;
        Serial.println("Manual T:4 — triggering calculator...");
        oocsi.newMessage("TEAM12_CALCULATOR");
        oocsi.addBool("start", true);
        oocsi.sendMessage();
        stepWithYield(stepsPerRevolution / numberOfPuzzles);
        printByte(B_);
      } else { Serial.println("T:4 already done."); }

    } else if (input == "T:5") {
      if (!calcDone) {
        calcDone = true;
        Serial.println("Manual T:5 — escape room complete!");
        stepWithYield(stepsPerRevolution / numberOfPuzzles);
        printByte(B_);
      } else { Serial.println("T:5 already done."); }

    } else {
      int incoming = input.toInt();
      if (incoming != 0) stepWithYield(incoming);
    }
  }
}

void setup() {
  Serial.begin(115200);

  lc.shutdown(0, false);
  lc.setIntensity(0, 8);
  lc.clearDisplay(0);

  // Quick test — all LEDs on so you can confirm it works before WiFi starts
  for (int i = 0; i < 8; i++) lc.setRow(0, i, 0xFF);
  delay(1000);
  lc.clearDisplay(0);

  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
    yield();
  }
  Serial.println(" connected!");

  myStepper.setSpeed(10);

  oocsi.connect("TEAM12_CENTRAL_MODULE", "oocsi.id.tue.nl", processMessage);
  Serial.println("OOCSI connected. Ready.");
  Serial.println("Commands: L:A-Z = show letter | T:1-5 = manual trigger | number = stepper steps");
}

void loop() {
  oocsi.check();
  calibrateClock();
}
