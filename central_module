#include <LedControl.h>
#include <ESP8266WiFi.h>
#include <OOCSI.h>
#include <Stepper.h>

// DIN=D7 (13), CLK=D5 (14), CS=D8 (15)
LedControl lc = LedControl(13, 14, 15, 1);

OOCSI oocsi;

const char* ssid     = "iotroam";
const char* password = "Welkom01!";

bool eyesDone      = false;
bool signalSent    = false;
bool highlightDone = false;
bool morseDone     = false;
bool calcDone      = false;

int stepsPerRevolution = 2090;
int numberOfPuzzles    = 5;

Stepper myStepper = Stepper(stepsPerRevolution, 5, 4, 12, 16);

byte A[]   = {B00000000, B00111100, B01100110, B01100110, B01111110, B01100110, B01100110, B01100110};
byte B_[]  = {B01111000, B01001000, B01001000, B01110000, B01001000, B01000100, B01000100, B01111100};
byte C[]   = {B00000000, B00011110, B00100000, B01000000, B01000000, B01000000, B00100000, B00011110};
byte D[]   = {B00000000, B00111000, B00100100, B00100010, B00100010, B00100100, B00111000, B00000000};
byte E[]   = {B00000000, B00111100, B00100000, B00111000, B00100000, B00100000, B00111100, B00000000};
byte F[]   = {B00000000, B00111100, B00100000, B00111000, B00100000, B00100000, B00100000, B00000000};
byte G[]   = {B00000000, B00111110, B00100000, B00100000, B00101110, B00100010, B00111110, B00000000};
byte H[]   = {B00000000, B00100100, B00100100, B00111100, B00100100, B00100100, B00100100, B00000000};
byte I[]   = {B00000000, B00111000, B00010000, B00010000, B00010000, B00010000, B00111000, B00000000};
byte J[]   = {B00000000, B00011100, B00001000, B00001000, B00001000, B00101000, B00111000, B00000000};
byte K[]   = {B00000000, B00100100, B00101000, B00110000, B00101000, B00100100, B00100100, B00000000};
byte L[]   = {B00000000, B00100000, B00100000, B00100000, B00100000, B00100000, B00111100, B00000000};
